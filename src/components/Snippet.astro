---
// src/components/Snippet.astro
// 4 tabs (CSS-only przez radio inputs + labels). Każdy snippet 5-7 linii copy-paste working.
// Lekka syntax kolorystyka: komentarze szare (HTML escape + regex per-language).

function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function highlightCode(code: string, lang: 'shell' | 'js' | 'python'): string {
  const escaped = escapeHtml(code);
  // Tylko komentarze — minimalna iniekcja syntax color, nie pełny IDE highlighting.
  if (lang === 'shell') {
    return escaped.replace(/^(#.*)$/gm, '<span class="token-comment">$1</span>');
  }
  if (lang === 'python') {
    return escaped.replace(/^(\s*#.*)$/gm, '<span class="token-comment">$1</span>');
  }
  // JS/TS — single-line + JSDoc-style
  return escaped.replace(/(\/\/.*)$/gm, '<span class="token-comment">$1</span>');
}

const apiBase = 'https://otwarteschroniska.org.pl/api/v1';  // post-domain swap to .org.pl

const snippets = {
  curl: `# Pobierz wszystkie schroniska + filtruj po mieście
curl ${apiBase}/shelters.json | jq '.[] | select(.miasto == "Wrocław")'`,
  js: `// W przeglądarce / Node 18+
const r = await fetch('${apiBase}/shelters.json');
const shelters = await r.json();
console.log(\`Łącznie: \${shelters.length} schronisk\`);`,
  python: `# Wymaga: pip install requests
import requests
shelters = requests.get('${apiBase}/shelters.json').json()
print(f"Łącznie: {len(shelters)} schronisk")
# Filtruj te z emailem:
with_email = [s for s in shelters if s.get('email')]`,
  node: `// Node.js 20+ (built-in fetch)
const r = await fetch('${apiBase}/shelters.json');
const data = await r.json();
const byWoj = data.reduce((acc, s) => {
  acc[s.wojewodztwo] = (acc[s.wojewodztwo] || 0) + 1;
  return acc;
}, {});
console.table(byWoj);`,
};
---

<div class="snippet-tabs">
  <input type="radio" name="snippet-lang" id="lang-curl" checked />
  <input type="radio" name="snippet-lang" id="lang-js" />
  <input type="radio" name="snippet-lang" id="lang-python" />
  <input type="radio" name="snippet-lang" id="lang-node" />

  <div class="tab-labels">
    <label for="lang-curl">curl</label>
    <label for="lang-js">JavaScript</label>
    <label for="lang-python">Python</label>
    <label for="lang-node">Node.js</label>
  </div>

  <div class="tab-content" data-tab="curl"><pre><code set:html={highlightCode(snippets.curl, 'shell')} /></pre></div>
  <div class="tab-content" data-tab="js"><pre><code set:html={highlightCode(snippets.js, 'js')} /></pre></div>
  <div class="tab-content" data-tab="python"><pre><code set:html={highlightCode(snippets.python, 'python')} /></pre></div>
  <div class="tab-content" data-tab="node"><pre><code set:html={highlightCode(snippets.node, 'js')} /></pre></div>
</div>

<style>
  .snippet-tabs { margin: 1rem 0; }
  .snippet-tabs input[type="radio"] { display: none; }

  .tab-labels {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .tab-labels label {
    padding: 0.55rem 1rem;
    cursor: pointer;
    font-size: 0.85rem;
    font-family: var(--font-mono);
    user-select: none;
    color: var(--color-muted);
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .tab-labels label:hover {
    color: var(--color-text);
    background: #fafafa;
  }

  .tab-content { display: none; margin-top: 0; }
  .tab-content pre { margin: 0; border-top: none; border-radius: 0 0 4px 4px; }

  /* Komentarze szare (lekka syntax kolorystyka) */
  .token-comment {
    color: #94a3b8;
    font-style: italic;
  }

  /* CSS-only tab switching */
  #lang-curl:checked ~ .tab-labels label[for="lang-curl"],
  #lang-js:checked ~ .tab-labels label[for="lang-js"],
  #lang-python:checked ~ .tab-labels label[for="lang-python"],
  #lang-node:checked ~ .tab-labels label[for="lang-node"] {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
    background: transparent;
  }
  #lang-curl:checked ~ .tab-content[data-tab="curl"],
  #lang-js:checked ~ .tab-content[data-tab="js"],
  #lang-python:checked ~ .tab-content[data-tab="python"],
  #lang-node:checked ~ .tab-content[data-tab="node"] {
    display: block;
  }
</style>
